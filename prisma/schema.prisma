generator client {
  provider = "prisma-client-js"
  output   = "../src/__generated__/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProcessedImage {
  id               String   @id @default(cuid())
  type             String
  prompt           String?
  fileName         String?
  resultUrl        String
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousOwnerId String?
  createdAt        DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousOwnerId, createdAt])
}

model ProcessingJob {
  id               String   @id @default(cuid())
  type             String
  status           String
  progress         Int      @default(0)
  inputKey         String?
  resultUrl        String?
  error            String?
  payload          Json?
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousOwnerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousOwnerId, createdAt])
}

model User {
  id              String           @id
  name            String
  email           String           @unique
  emailVerified   Boolean
  image           String?
  role            String           @default("user")
  banned          Boolean          @default(false)
  banReason       String?
  banExpires      DateTime?
  createdAt       DateTime
  updatedAt       DateTime
  sessions        Session[]
  accounts        Account[]
  processedImages ProcessedImage[]
  processingJobs  ProcessingJob[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
