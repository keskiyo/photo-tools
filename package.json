{
	"name": "phototools",
	"version": "0.1.0",
	"private": true,
	"packageManager": "yarn@1.22.22",
	"scripts": {
		"predev": "node scripts/kill-port.mjs 3000",
		"dev": "next dev --webpack -p 3000",
		"dev:all": "node scripts/dev-all.mjs",
		"build": "next build --webpack",
		"start": "next start",
		"worker:image": "tsx src/workers/image-worker.ts",
		"lint": "eslint",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:backend": "vitest run tests/backend",
		"test:frontend": "vitest run tests/frontend"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1076.0",
		"@prisma/client": "6.19.3",
		"better-auth": "^1.6.22",
		"bullmq": "^5.79.2",
		"ioredis": "^5.11.1",
		"lucide-react": "^1.21.0",
		"motion": "^12.42.0",
		"next": "16.2.9",
		"next-intl": "^4.13.0",
		"nextjs-toploader": "^3.9.17",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.80.0",
		"react-toastify": "^11.1.0",
		"resend": "^6.16.0",
		"sharp": "^0.35.2",
		"zod": "^4.4.3"
	},
	"overrides": {
		"postcss": "^8.5.10"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "^9",
		"eslint-config-next": "16.2.9",
		"prettier": "^3.9.3",
		"prisma": "6.19.3",
		"tailwindcss": "^4",
		"tsx": "^4.22.4",
		"typescript": "^5",
		"vitest": "^4.1.9",
		"yarn": "^1.22.22"
	}
}
